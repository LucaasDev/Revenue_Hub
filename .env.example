# ============================================================
# Supabase — valores públicos (expostos ao browser)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — valores secretos (server-only, NUNCA com prefixo NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_ID=your-project-id

# ============================================================
# App
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# Stripe — billing (Phase 4)
# ============================================================
# Chave secreta da conta Stripe (server-only)
STRIPE_SECRET_KEY=sk_live_...

# Webhook secret — gerado no Dashboard ou via `stripe listen`
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — criados em livemode na conta "Revenue"
# Produto: Revenue Hub Pro (prod_UCKk4hgGgFQwN3)
# Plano único Pro — modo Family é recurso incluso no Pro
STRIPE_PRO_MONTHLY_PRICE_ID=price_1TDwF2KnoHqEIp5vUMQHzkZ5
# R$19,99/mês
STRIPE_PRO_ANNUAL_PRICE_ID=price_1TDwF5KnoHqEIp5vi3ZJwWjk
# R$203,90/ano (15% de desconto — equivale a R$16,99/mês)

# ============================================================
# Sentry — error tracking (opcional em dev, obrigatório em prod)
# ============================================================
# DSN público — aparece nos source maps do browser
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# DSN server — usado no Node.js/Edge runtime
SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# Para upload de source maps no CI/CD
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=revenue-hub
SENTRY_AUTH_TOKEN=your-sentry-auth-token
